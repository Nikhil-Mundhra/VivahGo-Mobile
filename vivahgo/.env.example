# Frontend environment variables
VITE_GOOGLE_CLIENT_ID=your-google-web-client-id
VITE_API_BASE_URL=http://localhost:4000/api
VITE_USE_REMOTE_API=false
VITE_FEEDBACK_WEBHOOK_URL=https://script.google.com/macros/s/your-script-id/exec
VITE_FEEDBACK_SECRET_KEY=your-secret-key

# Backend environment variables
PORT=4000
MONGODB_URI=mongodb://127.0.0.1:27017/vivahgo
GOOGLE_CLIENT_ID=your-google-web-client-id
JWT_SECRET=your-long-random-jwt-secret
CLIENT_ORIGIN=http://localhost:5173,http://127.0.0.1:5173,https://your-production-domain.com